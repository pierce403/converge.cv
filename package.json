{
  "name": "converge.cv",
  "private": true,
  "version": "0.5.6",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-xmtp-wasm-worker.mjs",
    "prebuild": "node scripts/fix-xmtp-wasm-worker.mjs && node scripts/generate-build-info.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preview:cloudflare": "pnpm build && wrangler dev --env preview",
    "check": "pnpm typecheck && pnpm lint && pnpm test --run && pnpm build && pnpm check:cloudflare",
    "check:cloudflare": "wrangler deploy --dry-run --env=\"\"",
    "deploy": "pnpm check && wrangler deploy --env=\"\"",
    "deploy:preview": "pnpm check && wrangler deploy --env preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:coverage": "rm -rf coverage && vitest run --coverage",
    "test:e2e": "playwright test",
    "test:push:live": "node scripts/probe-live-push-relay.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
